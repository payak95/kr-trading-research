# kr-trading-research 환경변수 예시 — 복사해서 .env 로 채운다 (.env 는 절대 커밋 금지)
# 이 저장소는 브로커 자격증명이 전혀 없다(KIS/토스 무관 — 순수 연구/스크리닝/AI 판단 전용).

# ── 상태 저장소 / Redis(regime_scheduler 등 일부 도구에서 필요 — kr-trading-bot·kr-trading-bot-toss 와
# 같은 인스턴스 공유. 없어도 되는 스크립트가 대부분이라 기본은 비워둠, 예: redis://:password@redis:6379/0) ──
REDIS_URL=

# ── 텔레그램(스크리닝 신규 후보·전진검증 통과 알림 — kis 운영 봇과 별도 토큰 권장) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── AI 섀도 판단(tools/llm_shadow.py 등, 무주문·연구 전용) ──
# telegram-market-bot/kr-trading-bot 의 .env 와 동일 키를 그대로 재사용 가능.
GEMINI_API_KEY=

# ── 레짐 스케줄러(tools/regime_scheduler.py) — 흐름/Flow Upstash KV 의 변동성 신호를 읽어
# 전역 market:regime 기록(REDIS_URL 로 씀). Flow 의 KV REST URL + 읽기전용 토큰(Upstash 대시보드 발급). ──
FLOW_KV_REST_API_URL=
FLOW_KV_REST_API_TOKEN=

# ── 스크리닝 유니버스 크기(선택 — tools/screen_universe.py) ──
# SCREEN_UNIVERSE_POOL=450    # 1차: 시총 상위 풀(잡주 차단)
# SCREEN_UNIVERSE_SIZE=300    # 2차: 거래대금 상위 최종 N
